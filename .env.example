APP_ENV=local
APP_URL=http://localhost:8080

DB_DRIVER=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_NAME=lastmin
DB_USER=lastmin
DB_PASSWORD=lastmin
# Optional explicit DSN override. Leave empty to build DSN from DB_* values.
DB_DSN=

STRIPE_WEBHOOK_SECRET=dev-stripe-webhook-secret
# 'simulation' (default): stub gateway + clickable simulate endpoints.
# 'real': live Stripe API. Set STRIPE_SECRET_KEY (sk_test_... / sk_live_...),
# point a Stripe webhook (payment_intent.succeeded, payment_intent.payment_failed)
# at /api/v1/webhooks/stripe, and set STRIPE_WEBHOOK_SECRET to that endpoint's
# signing secret (whsec_...).
STRIPE_MODE=simulation
STRIPE_SECRET_KEY=
